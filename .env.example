# ECMR MCP - Environment Configuration
# 
# Copy this file to .env and configure for local development
# cp .env.example .env

# API Configuration
# Production: https://ecmr.api.release.cargoffer.com (default)
# Local development: http://localhost:8090
ECMR_API_URL=http://localhost:8090

# API Key - Get from Cargoffer dashboard or request access
ECMR_API_KEY=

# Server Port
PORT=3000